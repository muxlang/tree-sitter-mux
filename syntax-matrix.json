{
  "language": "Mux",
  "scope": "source.mux",
  "file_extensions": [".mux"],
  "keywords": {
    "control": [
      "if", "else", "for", "while", "match", "break", "continue"
    ],
    "declaration": [
      "auto", "func", "returns", "return", "const", "class", "interface",
      "enum", "import", "common", "where"
    ],
    "operator": ["is", "as", "in"],
    "constant": ["none"],
    "boolean_literals": ["true", "false"],
    "reserved": [
      "auto", "func", "returns", "return", "if", "else", "for", "while",
      "match", "const", "class", "interface", "enum", "import", "is",
      "as", "in", "break", "continue", "none", "common", "where"
    ],
    "note": "none is a tokenized keyword; some/ok/err are enum variant identifiers, not keywords"
  },
  "operators": {
    "assignment": [
      { "token": "Eq", "symbol": "=", "description": "assignment" },
      { "token": "PlusEq", "symbol": "+=", "description": "add assign" },
      { "token": "MinusEq", "symbol": "-=", "description": "subtract assign" },
      { "token": "StarEq", "symbol": "*=", "description": "multiply assign" },
      { "token": "SlashEq", "symbol": "/=", "description": "divide assign" },
      { "token": "PercentEq", "symbol": "%=", "description": "modulo assign" }
    ],
    "arithmetic": [
      { "token": "Plus", "symbol": "+", "description": "add" },
      { "token": "Minus", "symbol": "-", "description": "subtract" },
      { "token": "Star", "symbol": "*", "description": "multiply" },
      { "token": "StarStar", "symbol": "**", "description": "exponent" },
      { "token": "Slash", "symbol": "/", "description": "divide" },
      { "token": "Percent", "symbol": "%", "description": "modulo" },
      { "token": "Incr", "symbol": "++", "description": "increment" },
      { "token": "Decr", "symbol": "--", "description": "decrement" }
    ],
    "comparison": [
      { "token": "EqEq", "symbol": "==", "description": "equal" },
      { "token": "NotEq", "symbol": "!=", "description": "not equal" },
      { "token": "Lt", "symbol": "<", "description": "less than" },
      { "token": "Le", "symbol": "<=", "description": "less than or equal" },
      { "token": "Gt", "symbol": ">", "description": "greater than" },
      { "token": "Ge", "symbol": ">=", "description": "greater than or equal" }
    ],
    "logical": [
      { "token": "And", "symbol": "&&", "description": "logical and" },
      { "token": "Or", "symbol": "||", "description": "logical or" },
      { "token": "Bang", "symbol": "!", "description": "logical not" }
    ],
    "other": [
      { "token": "Ref", "symbol": "&", "description": "reference" },
      { "token": "Dot", "symbol": ".", "description": "member access" },
      { "token": "DotDot", "symbol": "..", "description": "range" }
    ]
  },
  "delimiters": [
    { "token": "OpenParen", "symbol": "(", "description": "open parenthesis" },
    { "token": "CloseParen", "symbol": ")", "description": "close parenthesis" },
    { "token": "OpenBrace", "symbol": "{", "description": "open brace" },
    { "token": "CloseBrace", "symbol": "}", "description": "close brace" },
    { "token": "OpenBracket", "symbol": "[", "description": "open bracket" },
    { "token": "CloseBracket", "symbol": "]", "description": "close bracket" },
    { "token": "Comma", "symbol": ",", "description": "comma" },
    { "token": "Colon", "symbol": ":", "description": "colon" }
  ],
  "literals": {
    "integer": { "token": "Int", "pattern": "[0-9][0-9_]*", "description": "64-bit integer" },
    "float": { "token": "Float", "pattern": "([0-9][0-9_]*\\.([0-9][0-9_]*)?|\\.[0-9][0-9_]*)([eE][-+]?[0-9][0-9_]*)?", "description": "64-bit float" },
    "boolean": { "token": "Bool", "values": ["true", "false"] },
    "char": { "token": "Char", "pattern": "'(\\\\.|[^'\\\\])'", "description": "single character" },
    "string": {
      "single_line": { "token": "Str", "pattern": "\"(\\\\.|[^\"\\\\])*\"", "description": "single-quoted string" },
      "multi_line": { "pattern": "\"\"\"(\\\\.|[^\"\\\\]|\\n)*\"\"\"", "description": "triple-quoted string" }
    },
    "underscore": { "token": "Underscore", "symbol": "_", "description": "wildcard in match patterns" }
  },
  "types": {
    "builtin": [
      "string", "bool", "void", "int", "float", "char", "optional", "result",
      "list", "map", "tuple", "set", "range", "Stringable", "Hashable",
      "Thread", "Error", "Self"
    ]
  },
  "identifiers": {
    "pattern": "[a-zA-Z][a-zA-Z0-9_]*",
    "underscore": "_"
  },
  "comments": {
    "line": { "token": "LineComment", "pattern": "//[^\n]*", "description": "single-line comment" },
    "block": { "token": "MultilineComment", "pattern": "/\\*[^*]*\\*+(?:[^/*][^*]*\\*+)*/", "description": "multi-line comment" }
  },
  "special_constructs": {
    "generics": { "description": "Enclosed in <>, e.g. result<int, string>", "note": "Uses Lt/Gt tokens, context-dependent" },
    "match_arms": { "description": "Pattern followed by {} block, no arrow token" },
    "enum_variants": { "description": "some/ok/err are user-facing variant identifiers, not keywords" },
    "references": { "description": "Prefix & for references, e.g. &T" }
  }
}
